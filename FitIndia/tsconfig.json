{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest", "react", "react-native"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src", "App.tsx"],
  "exclude": ["node_modules", "android", "ios", "Pods"]
}